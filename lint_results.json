>\n\n                 <div className=\"pt-8 space-y-4\">\n                    <h3 className=\"font-bold\">Follow Our Journey</h3>\n                    <div className=\"flex gap-3\">\n                       {[Linkedin, Globe].map((Icon, i) => (\n                         <button key={i} className=\"w-10 h-10 rounded-full bg-elite-primary-950 text-white flex items-center justify-center hover:bg-elite-accent-500 transition-colors\">\n                            <Icon size={18} />\n                         </button>\n                       ))}\n                    </div>\n                 </div>\n              </div>\n\n              {/* Contact Form */}\n              <div className=\"lg:col-span-2\">\n                 <Card className=\"border-none shadow-2xl overflow-hidden\">\n                    <CardContent className=\"p-8 md:p-12 space-y-8\">\n                       <div className=\"grid grid-cols-1 md:grid-cols-2 gap-6\">\n                          <Input label=\"Full Name\" placeholder=\"John Doe\" />\n                          <Input label=\"Email Address\" type=\"email\" placeholder=\"john@example.com\" />\n                       </div>\n                       <div className=\"space-y-1.5\">\n                          <label className=\"text-sm font-medium\">Subject</label>\n                          <select className=\"w-full h-10 px-3 rounded-lg border border-elite-primary-200 dark:border-elite-primary-800 bg-white dark:bg-elite-primary-950 text-sm\">\n                             <option>General Inquiry</option>\n                             <option>Technical Support</option>\n                             <option>Tutor Application</option>\n                             <option>Business Partnerships</option>\n                          </select>\n                       </div>\n                       <div className=\"space-y-1.5\">\n                          <label className=\"text-sm font-medium\">Message</label>\n                          <textarea\n                           className=\"w-full p-4 rounded-lg border border-elite-primary-200 dark:border-elite-primary-800 bg-white dark:bg-elite-primary-950 text-sm min-h-[200px] outline-none focus:ring-2 focus:ring-elite-primary-500\"\n                           placeholder=\"How can we help you?\"\n                          />\n                       </div>\n                       <Button variant=\"accent\" size=\"lg\" className=\"w-full\">\n                          Send Message <Send size={18} className=\"ml-2\" />\n                       </Button>\n                    </CardContent>\n                 </Card>\n              </div>\n           </div>\n        </div>\n      </main>\n\n      <Footer />\n    </div>\n  );\n}","usedDeprecatedRules":[]},{"filePath":"/app/src/app/courses/[courseId]/page.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'Area' is defined but never used.","line":4,"column":10,"nodeType":"Identifier","messageId":"unusedVar","endLine":4,"endColumn":14,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"Area"},"fix":{"range":[87,92],"text":""},"desc":"Remove unused variable \"Area\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'AreaChart' is defined but never used.","line":4,"column":16,"nodeType":"Identifier","messageId":"unusedVar","endLine":4,"endColumn":25,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"AreaChart"},"fix":{"range":[91,102],"text":""},"desc":"Remove unused variable \"AreaChart\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'Bar' is defined but never used.","line":4,"column":27,"nodeType":"Identifier","messageId":"unusedVar","endLine":4,"endColumn":30,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"Bar"},"fix":{"range":[102,107],"text":""},"desc":"Remove unused variable \"Bar\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'CartesianGrid' is defined but never us